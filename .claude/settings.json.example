{
  "//": "OPT-IN: copy this file to .claude/settings.json (or merge it) to auto-install",
  "//install": "this repo's skills into ~/.claude/skills at the start of every session.",
  "//useful-for": "Claude Code on the web / ephemeral containers where ~/.claude/skills is wiped between sessions.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/install-skills.sh",
            "timeout": 30,
            "statusMessage": "Installing repo skills into ~/.claude/skills..."
          }
        ]
      }
    ]
  }
}
